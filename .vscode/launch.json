{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tasks/app",
            "args": [
                "--factory",
                "fns:app_factory"
            ],
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Launch Frontend",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run start",
            "cwd": "${workspaceFolder}/views/fns_project"
        }
    ]
}
